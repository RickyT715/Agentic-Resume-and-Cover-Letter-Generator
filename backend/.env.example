# =============================================================================
# GEMINI API CONFIGURATION
# =============================================================================

# Required: Your Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (default: gemini-3-pro-preview)
# This application is optimized for Gemini 3 Pro
GEMINI_MODEL=gemini-3-pro-preview

# =============================================================================
# GEMINI GENERATION PARAMETERS
# =============================================================================

# Temperature: Controls randomness (0.0 = deterministic, 2.0 = very creative)
# Gemini 3 Pro is optimized for temperature=1.0 (default)
# GEMINI_TEMPERATURE=1.0

# Top-K: Gemini 3 Pro has a fixed value of 64 (cannot be changed)
# GEMINI_TOP_K=64

# Top-P (Nucleus Sampling): Cumulative probability threshold (0.0-1.0)
# Leave commented to use model default
# GEMINI_TOP_P=0.95

# Max Output Tokens: Maximum length of response (up to 64k for Gemini 3 Pro)
# Leave commented to use model default
# GEMINI_MAX_OUTPUT_TOKENS=8192

# Thinking Level: Controls reasoning depth (Gemini 3 Pro only)
# Options: low, high (default: high)
# - low:  Faster, lower latency, good for simple tasks
# - high: Deep reasoning (default), best for complex tasks like resume writing
# NOTE: Gemini 3 Pro always uses thinking (cannot be turned off)
GEMINI_THINKING_LEVEL=high

# =============================================================================
# GOOGLE SEARCH GROUNDING
# =============================================================================

# Enable Google Search grounding for real-time information
# Note: This incurs additional costs ($35 per 1,000 grounded queries)
# Set to true to enable web search for cover letter company research
# GEMINI_ENABLE_SEARCH=false

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# HOST=0.0.0.0
# PORT=8000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Log file rotation settings
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5
